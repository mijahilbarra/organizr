{
  "name": "organizr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:frontend": "vite --host 0.0.0.0 --port 5173",
    "dev:functions": "npm run functions:build && firebase emulators:start --only functions --project organizr-skip",
    "dev:firebase": "concurrently -k -n functions,frontend -c blue,green \"npm run dev:functions\" \"npm run dev:frontend\"",
    "stop:local": "bash scripts/kill-local-dev.sh",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "duplicates": "jscpd src server functions --min-lines 6 --min-tokens 40 --reporters console --ignore \"**/node_modules/**,**/lib/**,**/dist/**\"",
    "functions:build": "npm --prefix functions run build",
    "firebase:build": "npm run build && npm run functions:build",
    "tickets:read": "tsx scripts/read-tickets.ts",
    "tickets:create": "tsx scripts/create-ticket.ts",
    "tickets:update-state": "tsx scripts/update-ticket-state.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "firebase-tools": "^15.19.0",
    "jscpd": "^4.2.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
