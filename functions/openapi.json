{
  "openapi": "3.1.0",
  "info": {
    "title": "Organizr Custom GPT Actions",
    "description": "GPT-safe endpoints for checking user readiness and creating extractors from Gmail messages.",
    "version": "v1.0.0"
  },
  "servers": [
    {
      "url": "https://api-45fybwj2xq-uc.a.run.app"
    }
  ],
  "security": [
    {
      "CustomGptOAuth": [
        "profile",
        "gmail",
        "extractors"
      ]
    }
  ],
  "paths": {
    "/api/gpt/session/capabilities": {
      "get": {
        "description": "Check whether the authenticated user can run Custom GPT actions.",
        "operationId": "getGptSessionCapabilities",
        "deprecated": false,
        "responses": {
          "200": {
            "description": "The user is ready for GPT actions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionCapabilitiesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, or expired Firebase ID token."
          },
          "409": {
            "description": "User setup is incomplete and includes actionable next steps.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionCapabilitiesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gpt/extractors": {
      "get": {
        "operationId": "listGptExtractors",
        "description": "List the authenticated user's extractors with GPT-safe summary fields only.",
