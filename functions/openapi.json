    "/api/gpt/extractor-from-subject": {
      "post": {
        "description": "Search Gmail by subject, analyze matching emails, and persist a reusable extractor.",
        "operationId": "createExtractorFromGmailSubject",
        "deprecated": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "subject": {
                    "type": "string",
                    "description": "Gmail subject text to search for candidate messages."
                  },
                  "name": {
                    "type": "string",
                    "description": "Optional extractor display name."
                  },
                  "extractorId": {
                    "type": "string",
                    "description": "Optional existing extractor id. When provided, the analyzed subject is attached to that extractor instead of creating a new one."
                  },
                  "maxResults": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 20,
                    "default": 1
                  },
                  "webhookUrl": {
                    "type": "string",
                    "format": "uri"
                  },
                  "enabledSchedule": {
                    "type": "boolean",
                    "default": false
                  },
                  "provider": {
                    "type": "string",
                    "enum": [
                      "auto",
                      "gemini",
                      "openai",
                      "customgpt"
                    ],
                    "default": "auto"
                  }
                },
                "required": [
                  "subject"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extractor created, subject attached to an existing extractor, or Custom GPT manual analysis requested.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateExtractorFromSubjectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, or expired Firebase ID token."
          },
          "404": {
            "description": "No Gmail messages matched the subject, or the requested extractor was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "409": {
            "description": "User setup is incomplete or the subject already exists on the target extractor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "500": {
            "description": "Custom GPT orchestration failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "502": {
            "description": "Gmail analysis or extractor persistence failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gpt/extractor-from-analysis": {
      "post": {
        "description": "Persist an extractor using schema and parser analysis generated by Custom GPT.",
        "operationId": "createExtractorFromCustomGptAnalysis",
        "deprecated": false,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "subject": {
                    "type": "string"
                  },
                  "extractorId": {
                    "type": "string",
                    "description": "Optional existing extractor id. When provided, the analyzed subject is attached to that extractor instead of creating a new one."
                  },
                  "emails": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "analysis": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "explanation": {
                        "type": "string"
                      },
                      "schemaFields": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        }
                      },
                      "scriptCode": {
                        "type": "string"
                      },
                      "sampleExtractedResults": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        }
                      }
                    },
                    "required": [
                      "schemaFields",
                      "scriptCode"
                    ]
                  }
                },
                "required": [
                  "subject",
                  "analysis"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extractor created or subject attached to an existing extractor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateExtractorFromSubjectResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid Custom GPT analysis.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, or expired OAuth bearer token."
          },
          "404": {
            "description": "The requested extractor was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "409": {
            "description": "The subject already exists on the target extractor.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "500": {
            "description": "Custom GPT persistence orchestration failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          },
          "502": {
            "description": "Extractor persistence failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gpt/tickets": {
      "post": {
        "operationId": "createGptTicket",
