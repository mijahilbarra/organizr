              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GptActionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/gpt/extractors/{extractorId}": {
      "get": {
        "operationId": "getGptExtractor",
        "description": "Get one authenticated user's extractor with GPT-safe fields only.",
        "deprecated": false,
        "parameters": [
          {
            "name": "extractorId",
            "in": "path",
            "required": true,
