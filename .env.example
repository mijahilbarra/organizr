# Runtime
NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"
VITE_API_BASE_URL=""

# Gemini
GEMINI_API_KEY=""

# Firebase client SDK (frontend / Vite)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Firebase Admin SDK (backend / Functions local)
# In Firebase Functions production, prefer application default credentials.
FIREBASE_SERVICE_ACCOUNT=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
GOOGLE_APPLICATION_CREDENTIALS=""

# Firebase Functions
FIREBASE_FUNCTIONS_REGION="us-central1"
FIREBASE_FUNCTIONS_NAME="api"
FIREBASE_FUNCTIONS_EMULATOR_ORIGIN="http://127.0.0.1:5001"

# Gmail API
GMAIL_READONLY_SCOPE="https://www.googleapis.com/auth/gmail.readonly"

# Firestore profile document and extractor collection
FIRESTORE_DATABASE_ID="default"
VITE_FIRESTORE_DATABASE_ID="default"
FIRESTORE_USERS_COLLECTION="users"
FIRESTORE_EXTRACTORS_COLLECTION="extractors"
